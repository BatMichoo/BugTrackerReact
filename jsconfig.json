{
    "compilerOptions": {
        "baseUrl": ".",
        "paths": {
            "@/*": [
                "./*"
            ]
        },
        "checkJs": true,
        "jsx": "react-jsx",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "target": "ESNext",
        "strict": false,
        "strictNullChecks": false,
        "noImplicitAny": false,
        "noImplicitThis": false,
        "strictFunctionTypes": false,
        "allowJs": true,
        "skipLibCheck": true,
        "esModuleInterop": true,
        "allowSyntheticDefaultImports": true,
        "noEmit": true,
        "allowImportingTsExtensions": true,
        "resolveJsonModule": true
    },
    "include": [
        "src/**/*",
        "**/*.js",
        "**/*.jsx",
    ],
    "exclude": [
        "node_modules",
        "dist",
        "build"
    ]
}
